    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "id": 2,
      "title": "Requests per Second",
      "type": "timeseries",
      "targets": [{ "expr": "rate(http_requests_total[5m])", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "id": 3,
      "title": "p95 Latency",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 4,
      "title": "Pipeline Latency Breakdown (Per Node)",
      "type": "timeseries",
      "targets": [{ "expr": "rate(node_duration_seconds_sum[5m]) / rate(node_duration_seconds_count[5m])", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "id": 5,
      "title": "Detailed Cache Hit Rate",
      "type": "gauge",
      "targets": [{ "expr": "sum(rate(cache_hits_total[5m])) by (cache_type) / sum(rate(cache_requests_total[5m])) by (cache_type)", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "id": 6,
      "title": "CRAG Score Distribution",
