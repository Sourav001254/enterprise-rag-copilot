      "targets": [{ "expr": "sum(rate(crag_score_bucket[5m])) by (le)", "refId": "A", "format": "heatmap" }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "id": 7,
      "title": "Self-RAG Loops",
      "type": "bargauge",
      "targets": [{ "expr": "sum(rate(self_rag_loops_total[1h])) by (intent)", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "id": 8,
      "title": "Error Rates by Intent",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (intent)", "refId": "A" }]
