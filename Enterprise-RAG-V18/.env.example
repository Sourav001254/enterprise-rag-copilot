# GCP
GCP_PROJECT_ID=enterprise-rag
GCP_REGION=us-central1

# Database
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_db
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=k8s_docs

# Cache (Set to your local redis for dev, Upstash for prod)
UPSTASH_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_TOKEN=

# LLM Keys
OPENAI_API_KEY=sk-xxxx
PORTKEY_API_KEY=
PORTKEY_VIRTUAL_KEY_PRIMARY=
GROQ_API_KEY=
VOYAGE_API_KEY=
TAVILY_API_KEY=

# Auth
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256

# Observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=enterprise-rag-k8s
LOGFIRE_TOKEN=
